{
    "indir": "input",
    "outdir": "output",
    "logdir": "log",
    "genome": {
        "index_prefix": "/path/to/bowtie2_index/genome",
        "fasta": "/path/to/genome.fa"
    },
    "Procedure": {
        "bowtie2-build": "path/to/bowtie2-build",
        "bowtie2": "path/to/bowtie2",
        "samtools": "path/to/samtools"
    },
    "Params": {
        "bowtie2": {
            "sam-append-comment": true
        }
    },
    "paired_samples": ["sample1", "sample2"],
    "single_samples": ["sample3", "sample4"]
}