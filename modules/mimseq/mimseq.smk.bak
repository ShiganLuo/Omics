from snakemake.logging import logger
include: "../common/common.smk"

ROOT_DIR = config.get("ROOT_DIR", ".")
# Import UMI detection helper from bin/
_mimseq_bin_dir = os.path.join(ROOT_DIR, "modules", "mimseq", "bin")
if _mimseq_bin_dir not in sys.path:
    sys.path.insert(0, _mimseq_bin_dir)
from utils import extract_condition
indir = config.get("indir", "input")
outdir = config.get("outdir", "output")
logdir = config.get("logdir", "log")
samples = config.get("samples", [])
meta = config.get("meta", "")

def get_mimseq_input():
    fastqs = [os.path.join(indir, sample_id, f"{sample_id}.single.fq.gz") for sample_id in samples]
    meta = config.get("meta", "")
    in_dict = {
        "fastqs": fastqs,
        "meta": meta,
    }
    if not os.path.exists(meta):
        raise FileNotFoundError(f"Metadata file {meta} not found.")
    if config.get("Params", {}).get("mimseq", {}).get("species", "") not in ["Hsap", "Hsap38", "Mmus", "Scer", "Spom", "Dmel", "Drer", "Ecol"]:
        logger.info("Custom tRNA references provided. Checking existence...")
        trnas = config.get("genome", {}).get("trnas", "")
        trnaout = config.get("genome", {}).get("trnaout", "")
        if not os.path.exists(trnas):
            raise FileNotFoundError(f"tRNA reference file {trnas} not found.")
        if not os.path.exists(trnaout):
            raise FileNotFoundError(f"tRNA output file {trnaout} not found.")
        in_dict["trnas"] = trnas
        in_dict["trnaout"] = trnaout
    return in_dict

rule mimseq_run:
    """Run mim-tRNAseq pipeline: alignment, coverage, modification quantification, DESeq2."""
    input:
        **get_mimseq_input()
    output:
        outdir = directory(outdir),
    log:
        logdir + "/a_collect/mimseq/mimseq_run.log"
    conda:
        "mimseq.yaml"
    threads: 30
    params:
        mimseq = config.get("Procedure", {}).get("mimseq") or "mimseq",
        species = config.get("Params", {}).get("mimseq", {}).get("species") or "",
        name = config.get("Params", {}).get("mimseq", {}).get("name") or "tranout",
        control_condition = config.get("Params", {}).get("mimseq", {}).get("control_condition") or None,
        cluster_id = config.get("Params", {}).get("mimseq", {}).get("cluster_id") or 0.97,
        min_cov = config.get("Params", {}).get("mimseq", {}).get("min_cov") or 0.0005,
        max_mismatches = config.get("Params", {}).get("mimseq", {}).get("max_mismatches") or 0.075,
        max_multi = config.get("Params", {}).get("mimseq", {}).get("max_multi") or 4,
        misinc_thresh = config.get("Params", {}).get("mimseq", {}).get("misinc_thresh") or 0.1,
        remap_mismatches = config.get("Params", {}).get("mimseq", {}).get("remap_mismatches") or 0.05,
        p_adj = config.get("Params", {}).get("mimseq", {}).get("p_adj") or 0.05,
        mito_trnas = config.get("genome", {}).get("mito_trnas") or "",
        plastid_trnas = config.get("genome", {}).get("plastid_trnas") or "",
        no_cluster = config.get("Params", {}).get("mimseq", {}).get("no_cluster") or False,
        no_cca = config.get("Params", {}).get("mimseq", {}).get("no_cca") or False,
        double_cca = config.get("Params", {}).get("mimseq", {}).get("double_cca") or False,
        remap = config.get("Params", {}).get("mimseq", {}).get("remap") or True,
        snp_tolerance = config.get("Params", {}).get("mimseq", {}).get("snp_tolerance") or True,
        keep_temp = config.get("Params", {}).get("mimseq", {}).get("keep_temp") or False,
        crosstalks = config.get("Params", {}).get("mimseq", {}).get("crosstalks") or False,
        pretRNAs = config.get("Params", {}).get("mimseq", {}).get("pretRNAs") or False,
        posttrans = config.get("Params", {}).get("mimseq", {}).get("posttrans_mod_off") or False,
        cov_diff = config.get("Params", {}).get("mimseq", {}).get("cov_diff") or 0.5,
        local_mod = config.get("Params", {}).get("mimseq", {}).get("local_modomics") or False,
    run:
        try:
            log_path = str(log)
            open(log_path, "w").close()
            current_time = time.strftime("%Y%m%d_%H%M%S", time.localtime())
            script_path = os.path.join(outdir, f"mimseq_run_{current_time}.sh")

            sample_data_path = os.path.join(outdir, "sample_data.tsv")
            sample_condition_dict = extract_condition(input.meta)
            os.makedirs(outdir, exist_ok=True)
            with open(os.path.join(sample_data_path), "w") as f:
                for sample_id in samples:
                    if sample_id not in sample_condition_dict:
                        raise ValueError(f"Sample {sample_id} not found in metadata file {input.meta}.")
                    design = sample_condition_dict[sample_id]
                    f.write(f"{os.path.join(indir, sample_id, f'{sample_id}.single.fq.gz')}\t{design}\n")
            if not os.path.exists(sample_data_path):
                raise FileNotFoundError(f"Sample data file {sample_data_path} not found, which should have two columns: fastq paths and conditions separated by tab.")
            # Build command
            cmd = [params.mimseq]

            # Species or custom tRNA references
            # mimseq bug: -o is always required even with -s, so we must provide it
            mimseq_bin = shell("which mimseq 2>/dev/null || echo ''", read=True).strip()
            if not mimseq_bin:
                raise FileNotFoundError("mimseq executable not found in PATH. Please ensure mimseq is installed and conda environment is activated.")
            mimseq_data_dir = os.path.join(os.path.dirname(os.path.dirname(mimseq_bin)), "lib", "python3.7", "site-packages", "mimseq", "data")
            species_trnaout_map = {
                "Hsap": "hg38-eColitK/hg38-tRNAs-detailed.out",
                "Hsap19": "hg19-eColitK/hg19_eschColi-tRNAs.out",
                "Mmus": "mm39-eColitK/mm39-tRNAs-detailed.out",
                "Scer": "sacCer3-eColitK/sacCer3_eschColi-tRNAs.out",
                "Spom": "schiPomb-eColitK/schiPomb_eschColi-tRNAs.out",
                "Dmel": "dm6-eColitK/dm6_eschColi-tRNAs.out",
                "Drer": "danRer11-eColitK/danRer11_eschColi-tRNAs.out",
                "Cele": "ce11-eColitK/ce11-tRNAs-detailed.out",
                "Ecol": "eschColi-K_12_MG1655-tRNAs/eschColi_K_12_MG1655-tRNAs.out",
            }
            if params.species:
                cmd += ["-s", params.species]
                # Provide -o to work around mimseq bug
                if params.species in species_trnaout_map:
                    trnaout_path = os.path.join(mimseq_data_dir, species_trnaout_map[params.species])
                    if os.path.exists(trnaout_path):
                        cmd += ["-o", trnaout_path]
                    else:
                        logger.warning(f"tRNA.out file not found for {params.species}: {trnaout_path}")
                else:
                    logger.warning(f"Unknown species {params.species}, cannot auto-provide -o")
            else:
                cmd += ["-t", input.trnas, "-o", input.trnaout]
                if params.mito_trnas:
                    cmd += ["-m", params.mito_trnas]
                if params.plastid_trnas:
                    cmd += ["-p", params.plastid_trnas]
            if params.control_condition and params.control_condition in sample_condition_dict.values():
                logger.info(f"Control condition specified: {params.control_condition}. all condtion in {list(sample_condition_dict.values())} but not control condition will be compared to control condition.")
                cmd += ["--control-condition", params.control_condition]
            else:
                logger.warning(f"Control condition specified: {params.control_condition} but not found in sample conditions {list(sample_condition_dict.values())}. Differential analysis will not be performed.")
                cmd += ["--control-condition", " ".join(dict.fromkeys(sample_condition_dict.values()))]  # Use all unique conditions if control condition is not found
            # Required options
            cmd += [
                "-n", params.name,
                "--out-dir", outdir,
                "--threads", str(threads),
                "--cluster-id", str(params.cluster_id),
                "--min-cov", str(params.min_cov),
                "--max-mismatches", str(params.max_mismatches),
                "--max-multi", str(params.max_multi),
                "--misinc-thresh", str(params.misinc_thresh),
                "--remap-mismatches", str(params.remap_mismatches),
                "--p-adj", str(params.p_adj),
                "--deconv-cov-ratio", str(params.cov_diff),
            ]

            # Boolean flags
            if params.no_cluster:
                cmd += ["--no-cluster"]
            if params.no_cca:
                cmd += ["--no-cca-analysis"]
            if params.double_cca:
                cmd += ["--double-cca"]
            if params.remap:
                cmd += ["--remap"]
            if not params.snp_tolerance:
                cmd += ["--no-snp-tolerance"]
            if params.keep_temp:
                cmd += ["--keep-temp"]
            if params.crosstalks:
                cmd += ["--crosstalks"]
            if params.pretRNAs:
                cmd += ["--pretRNAs"]
            if params.posttrans:
                cmd += ["--posttrans-mod-off"]
            if params.local_mod:
                cmd += ["--local-modomics"]

            # Sample data (positional, must be last)
            cmd += [sample_data_path]

            with open(script_path, "w") as f:
                f.write("#!/bin/bash\n")
                f.write("set -e\n")
                f.write(" ".join(cmd) + "\n")
            shell(f"bash {script_path} >> {log_path} 2>&1")
        except Exception as e:
            with open(log_path, "a") as f:
                f.write(f"mimseq_run failed: {e}\n")
            raise

# ========================
# Result aggregation
# ========================

rule mimseq_result:
    """Aggregate mimseq outputs as dependency endpoint."""
    input:
        outdir = outdir,
