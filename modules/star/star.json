            "alignSJDBoverhangMin": 3,
            "chimSegmentMin": 0,
            "chimOutType": "Junctions",
            "chimJunctionOverhangMin": 20,
            "outSAMstrandField": null,
            "chimScoreMin": 0,
            "chimScoreDropMax": 20,
            "chimScoreJunctionNonGTAG": -1,
            "chimScoreSeparation": 10,
            "alignSJstitchMismatchNmax": "0 -1 0 0",
            "chimSegmentReadGapMax": 0
