{
    "indir": "output/hisat2",
    "outdir": "output",
    "logdir": "logs",
    "paired_samples": ["sample1", "sample2"],
    "single_samples": ["sample3", "sample4"],
    "Procedure": {
        "STAR": "path/to/STAR"
    },
    "genome": {
        "fasta": "path/to/genome.fa",
        "gtf": "path/to/annotation.gtf",
